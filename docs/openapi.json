  "components": {
    "schemas": {
      "AccountCreateRequest": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "amount": {
            "type": "number",
            "title": "Amount"
          },
          "currency_code": {
            "type": "string",
            "title": "Currency Code"
          }
        },
        "type": "object",
        "required": [
          "name",
          "amount",
          "currency_code"
        ],
        "title": "AccountCreateRequest"
      },
      "AccountDto": {
        "properties": {
          "id": {
            "type": "integer",
            "title": "Id"
          },
          "user_id": {
            "type": "integer",
            "title": "User Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "amount": {
            "type": "number",
            "title": "Amount"
          },
          "amount_rubles": {
            "type": "number",
            "title": "Amount Rubles"
          },
          "currency_code": {
            "type": "string",
            "title": "Currency Code"
          }
        },
        "type": "object",
        "required": [
          "id",
          "user_id",
          "name",
          "amount",
          "amount_rubles",
          "currency_code"
        ],
        "title": "AccountDto"
      },
      "AccountUpdateRequest": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name"
          },
          "amount": {
            "type": "number",
            "title": "Amount"
          }
        },
        "type": "object",
        "required": [
          "name",
          "amount"
        ],
        "title": "AccountUpdateRequest"
      },
      "AccountsResponse": {
        "properties": {
          "accounts": {
            "additionalProperties": {
              "$ref": "#/components/schemas/AccountDto"
            },
            "type": "object",
            "title": "Accounts"
          },
          "total": {
            "type": "integer",
            "title": "Total"
          },
          "total_amount_rubles": {
            "type": "number",
            "title": "Total Amount Rubles"
          }
        },
        "type": "object",
        "required": [
          "accounts",
          "total",
          "total_amount_rubles"
        ],
        "title": "AccountsResponse"
      },
      "AuthResponse": {
        "properties": {
          "access_token": {
            "type": "string",
            "title": "Access Token"
          },
          "refresh_token": {
            "type": "string",
            "title": "Refresh Token"
          },
          "token_type": {
            "type": "string",
            "const": "bearer",
            "title": "Token Type",
            "default": "bearer"
          },
          "expires_in": {
            "type": "integer",
            "title": "Expires In"
          }
        },
        "type": "object",
        "required": [
          "access_token",
          "refresh_token",
          "expires_in"
        ],
        "title": "AuthResponse"
      },
      "CategoriesResponse": {
        "properties": {
          "categories": {
            "additionalProperties": {
              "$ref": "#/components/schemas/CategoryDto"
            },
            "type": "object",
            "title": "Categories"
          }
        },
        "type": "object",
        "required": [
